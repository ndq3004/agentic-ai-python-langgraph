# Copy this file to .env and fill in your values.

# ── LLM providers ──────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_OPENAI_API_KEY=

# ── Video generation backend ────────────────────────────────────────────────
# Options:
#   stub       — no real video (default, always works)
#   local      — Wan2.1 on your NVIDIA GPU (requires CUDA drivers + 8GB+ VRAM)
#   replicate  — Wan2.1 via Replicate cloud GPU API (requires REPLICATE_API_TOKEN)
VIDEO_BACKEND=stub

# Required only if VIDEO_BACKEND=replicate
# Get your token at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
